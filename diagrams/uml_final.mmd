classDiagram
    class PriorityLevel {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class TaskStatus {
        <<enumeration>>
        PENDING
        COMPLETED
    }

    class Task {
        +task_id: str
        +title: str
        +description: str
        +duration: int
        +scheduled_time: datetime?
        +frequency: str
        +priority_level: PriorityLevel
        +owner_preferences: str?
        +constraints: str?
        +pet_id: str?
        +owner_id: str?
        +status: TaskStatus
        +mark_complete()
        +create_next_occurrence(pet, owner) Task?
        +is_completed() bool
        +to_summary() str
    }

    class Pet {
        +pet_id: str
        +name: str
        +species: str
        +breed: str?
        +age: int?
        +tasks: List[Task]
        +add_task(task) bool
        +remove_task(task_id) bool
        +get_tasks(status) List[Task]
        +update_profile(name, species, breed, age)
    }

    class Owner {
        +owner_id: str
        +name: str
        +email: str
        +phone: str?
        +pets: List[Pet]
        +add_pet(pet) bool
        +create_task(...) Task
        +get_all_tasks() List[Task]
        +get_tasks_for_pet(pet_id) List[Task]
        +get_pending_tasks() List[Task]
        +view_schedule() List[Task]
    }

    class Scheduler {
        +retrieve_tasks(owner) List[Task]
        +organize_tasks(owner, include_completed) List[Task]
        +sort_by_time(tasks) List[Task]
        +filter_tasks(tasks, status, pet_name, owner) List[Task]
        +mark_task_complete(owner, task_id) bool
        +detect_conflicts(tasks) List[str]
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : contains
    Owner "1" --> "0..*" Task : creates/associates
    Task --> PriorityLevel : uses
    Task --> TaskStatus : uses
    Scheduler ..> Owner : reads/manages
    Scheduler ..> Task : sorts/filters/conflicts
